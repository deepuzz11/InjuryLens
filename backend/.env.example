# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a key is auto-generated on first run and appended here.
SECRET_KEY=

# ── Email / SMTP (required for password-reset emails) ─────────────────────────
# Gmail example: use an App Password (not your real password).
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=InjuryLens <your_email@gmail.com>

# Public URL used in reset-link emails (change for production deployment)
APP_URL=http://localhost:5173
